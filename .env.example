OPENAI_API_KEY=
TOGETHER_API_KEY=
GEMINI_API_KEY=your_gemini_api_key_here
AI_PROVIDER=auto
DEMO_MODE=false

# Copy this file to .env and replace the placeholder values with your real keys.
# Never commit your real API keys or secrets to version control.
# AI_PROVIDER can be one of: auto, openai, gemini, deepseek, together, local

# DeepSeek settings
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com  # or http://localhost:8000/ for local
# Recommended models: deepseek-v4-pro (best), deepseek-v4-flash (fast/economical)
